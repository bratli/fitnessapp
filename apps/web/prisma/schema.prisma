generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String              @id @default(cuid())
  username        String              @unique
  email           String              @unique
  passwordHash    String
  name            String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  workouts        Workout[]
  favourites      FavouriteExercise[]
  badges          UserBadge[]
}

model Exercise {
  id               String              @id @default(cuid())
  name             String
  description      String?
  videoUrl         String?
  bodyPart         String
  level            Int                 @default(1)
  defaultSets      Int                 @default(3)
  defaultReps      String              @default("8-12")
  createdAt        DateTime            @default(now())
  workoutExercises WorkoutExercise[]
  favouritedBy     FavouriteExercise[]

  @@unique([name, bodyPart, level])
}

model FavouriteExercise {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
}

model Workout {
  id          String            @id @default(cuid())
  name        String
  date        DateTime          @default(now())
  completed   Boolean           @default(false)
  completedAt DateTime?
  difficulty  Int?
  mood        Int?
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  exercises   WorkoutExercise[]
  templateId  String?
  template    Workout?          @relation("WorkoutSessions", fields: [templateId], references: [id])
  sessions    Workout[]         @relation("WorkoutSessions")

  @@index([userId])
}

model WorkoutExercise {
  id         String        @id @default(cuid())
  order      Int
  workoutId  String
  workout    Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise      @relation(fields: [exerciseId], references: [id])
  sets       ExerciseSet[]

  @@unique([workoutId, order])
  @@index([workoutId])
}

model ExerciseSet {
  id                String          @id @default(cuid())
  setNumber         Int
  reps              Int?
  weight            Float?
  duration          Int?
  completed         Boolean         @default(false)
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutExerciseId, setNumber])
  @@index([workoutExerciseId])
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}
